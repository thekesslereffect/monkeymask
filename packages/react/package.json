{
  "name": "@monkeymask/react",
  "version": "0.2.1",
  "description": "React hooks and provider for MonkeyMask Banano wallet",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/thekesslereffect/monkeymask.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/thekesslereffect/monkeymask/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/thekesslereffect/monkeymask/issues"
  },
  "keywords": [
    "banano",
    "wallet",
    "react",
    "hooks",
    "monkeymask",
    "wallet-standard"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external react --external react-dom",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@monkeymask/wallet-standard": "0.2.0",
    "@wallet-standard/app": "^1.1.0",
    "@wallet-standard/base": "^1.1.0",
    "@wallet-standard/features": "^1.1.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.0.0"
  }
}
