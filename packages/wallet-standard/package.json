{
  "name": "@monkeymask/wallet-standard",
  "version": "0.2.0",
  "description": "Banano Wallet Standard types, SIWB, and protocol for MonkeyMask",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@wallet-standard/base": "^1.1.0",
    "@wallet-standard/features": "^1.1.0"
  },
  "peerDependencies": {
    "@bananocoin/bananojs": ">=2.8.0"
  },
  "peerDependenciesMeta": {
    "@bananocoin/bananojs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@bananocoin/bananojs": "^2.10.10",
    "tsup": "^8.5.0",
    "typescript": "^5.0.0"
  }
}
